{
  "name": "mdpr-ppt",
  "version": "0.1.0",
  "private": false,
  "description": "PowerPoint add-in bridge for MDPR object inspection, approved selection capture, and component transform candidates.",
  "type": "module",
  "bin": {
    "mdpr-ppt": "./bin/mdpr-ppt.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsx tests/shared.test.ts",
    "serve:addin": "node scripts/serve-addin.mjs",
    "start:ppt": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-powerpoint-addin-windows.ps1",
    "start:ppt:debug": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-powerpoint-addin-windows.ps1 -Debug",
    "stop:ppt": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-powerpoint-addin-windows.ps1",
    "install:addin:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-addin-windows.ps1",
    "install:addin:windows:register": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-addin-windows.ps1 -TryShare -RegisterTrustCatalog",
    "validate": "npm run typecheck && npm test"
  },
  "keywords": [
    "mdpr",
    "powerpoint",
    "powerpoint-addin",
    "office-js",
    "office-addin",
    "pptx",
    "pptx-automation",
    "markdown-to-powerpoint"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
